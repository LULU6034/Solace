{
  "name": "solace",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port ${VITE_PORT:-5173}\" \"wait-on http://localhost:${VITE_PORT:-5173} && cross-env ELECTRON_IS_DEV=true VITE_PORT=${VITE_PORT:-5173} electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env ELECTRON_IS_DEV=true electron .",
    "electron:build": "vite build && node scripts/gen-icons.cjs && electron-builder",
    "electron:release": "vite build && node scripts/gen-icons.cjs && electron-builder --publish always",
    "gen-icons": "node scripts/gen-icons.cjs",
    "postinstall": "patch-package"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@browserbasehq/stagehand": "^3.5.0",
    "@kreuzberg/node": "^4.9.9",
    "@neteasecloudmusicapienhanced/api": "^4.35.1",
    "@phosphor-icons/vue": "^2.2.1",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.17",
    "canvas": "^3.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-updater": "^6.8.9",
    "gsap": "^3.15.0",
    "hono": "^4.12.23",
    "js-yaml": "^4.1.1",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.4",
    "openai": "^6.38.0",
    "opencc-js": "^1.3.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0",
    "three": "^0.184.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.34",
    "vue-boring-avatars": "^1.4.0",
    "wait-on": "^9.0.10",
    "ws": "^8.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "patch-package": "^8.0.1",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.solace.app",
    "productName": "Solace",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "plugins-builtin/**/*",
      "skills-builtin/**/*",
      "data/**/*",
      "public/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/lazy-val/**/*",
      "!node_modules/**/*"
    ],
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "LULU6034",
      "repo": "Solace"
    }
  }
}
